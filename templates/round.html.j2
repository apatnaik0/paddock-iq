<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PaddockIQ | {{ event_name }}</title>
  <style>
    :root {
      --bg: #090c11;
      --panel: #121720;
      --panel-2: #171f2b;
      --ink: #edf3ff;
      --muted: #9db0cc;
      --line: #2b3647;
      --accent: #4ea1ff;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Avenir Next", "Segoe UI", sans-serif;
      font-size: 19px;
      line-height: 1.45;
      background: radial-gradient(circle at 15% 5%, #121b2a 0%, var(--bg) 48%, #07090d 100%);
      color: var(--ink);
    }
    .wrap { max-width: 1420px; margin: 0 auto; padding: 22px 16px 52px; }
    .head {
      background: linear-gradient(145deg, #141b28 0%, #0f141d 100%);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
      margin-bottom: 12px;
      position: sticky;
      top: 0;
      z-index: 20;
      min-height: 160px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .brand { margin: 0; color: #e9f2ff; font-size: 1.06rem; font-weight: 800; letter-spacing: 0.3px; }
    .topnav { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 10px; }
    .navbtn {
      text-decoration: none;
      font-weight: 700;
      border-radius: 999px;
      padding: 8px 14px;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: #071222;
    }
    .navbtn.inactive {
      color: #dfe8f7;
      background: #111a28;
      border-color: #31405a;
    }
    h1 { margin: 0 0 6px; font-size: 2rem; letter-spacing: 0.2px; }
    .muted { color: var(--muted); margin: 0; font-size: 1.08rem; }

    .top-tabs, .sub-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }
    .tab-btn {
      border: 1px solid var(--line);
      background: var(--panel-2);
      color: var(--ink);
      padding: 8px 14px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 600;
      font-size: 1.12rem;
    }
    .tab-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #071222;
    }

    .tab-panel { display: none; margin-top: 8px; }
    .tab-panel.active { display: block; }

    .session {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px;
    }
    .session h2 { margin: 0 0 6px; font-size: 1.32rem; }
    .meta { display: flex; gap: 12px; flex-wrap: wrap; color: var(--muted); font-size: 1.08rem; }

    .imggrid {
      display: block;
      margin-top: 6px;
    }
    .chart {
      background: #0f141d;
      border: 1px solid #273246;
      border-radius: 10px;
      padding: 6px;
      margin-bottom: 6px;
    }
    .chart h3 { margin: 0 0 8px; font-size: 1.14rem; color: #dce8f9; }
    img {
      width: 100%;
      max-height: 520px;
      object-fit: contain;
      border-radius: 6px;
      border: 1px solid #2a3447;
      background: #0b0f16;
    }
    img.telemetry-large {
      max-height: 900px;
    }

    .insight-box {
      margin-top: 8px;
      border: 1px solid #243245;
      border-radius: 8px;
      padding: 6px 8px;
      background: #0f141d;
    }
    .insight-title {
      color: #c4d3ea;
      font-size: 1.12rem;
      font-weight: 700;
      margin: 0 0 4px;
    }
    .insight-box ul {
      margin: 0;
      padding-left: 16px;
      color: #d7e3f6;
      font-size: 1.08rem;
    }

    table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 1.1rem; }
    th, td { text-align: left; border-bottom: 1px solid #223042; padding: 7px 4px; }
    th { color: #bfd1ea; font-weight: 600; }
    td { color: #dfe8f7; }

    .empty {
      border: 1px dashed #33435b;
      border-radius: 10px;
      padding: 10px;
      color: var(--muted);
      margin-top: 8px;
      background: #0f141d;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="head">
      <p class="brand">PaddockIQ</p>
      <h1>Weekend Analysis</h1>
      <p class="muted">{{ season }} Round {{ round_number }} | {{ event_name }}</p>
      <nav class="topnav">
        <a class="navbtn inactive" href="../../index.html">Race Hub</a>
        <a class="navbtn inactive" href="index.html">Overview</a>
        <a class="navbtn" href="round.html">Weekend Analysis</a>
        <a class="navbtn inactive" href="strategy.html">Strategy Lab</a>
      </nav>
    </section>

    <nav class="top-tabs">
      <button class="tab-btn active" data-group="main" data-target="practice-panel">Practice</button>
      <button class="tab-btn" data-group="main" data-target="qualifying-panel">Qualifying</button>
      <button class="tab-btn" data-group="main" data-target="race-panel">Race</button>
    </nav>

    <section id="practice-panel" class="tab-panel active">
      <nav class="sub-tabs">
        {% for s in practice_sessions %}
        <button class="tab-btn {% if loop.first %}active{% endif %}" data-group="practice" data-target="practice-{{ s.session_name|lower }}">{{ s.session_name }}</button>
        {% endfor %}
      </nav>
      {% for s in practice_sessions %}
      <div id="practice-{{ s.session_name|lower }}" class="tab-panel {% if loop.first %}active{% endif %}">
        <article class="session">
          <h2>{{ s.session_name }}</h2>
          <div class="meta"><span>Drivers: {{ s.drivers }}</span><span>Laps: {{ s.laps }}</span></div>
          <div class="imggrid">
            {% for chart in s.charts %}
            <article class="chart">
              <h3>{{ chart.title }}</h3>
              <img class="{% if chart.title == 'Fastest Two Lap Delta' %}telemetry-large{% endif %}" src="assets/{{ chart.file }}?v={{ asset_version }}" alt="{{ s.session_name }} {{ chart.title }}" />
              <div class="insight-box">
                <p class="insight-title">Highlights</p>
                <ul>
                  {% for point in chart.insights %}
                  <li>{{ point }}</li>
                  {% endfor %}
                </ul>
              </div>
            </article>
            {% endfor %}
          </div>
          <table>
            <thead><tr><th>Pos</th><th>Driver</th><th>Team</th><th>Top-5 Avg Pace</th><th>Laps</th></tr></thead>
            <tbody>
              {% for r in s.table_rows %}
              <tr><td>{{ r.session_position }}</td><td>{{ r.Driver }}</td><td>{{ r.Team }}</td><td>{{ r.top5_avg_pace_fmt }}</td><td>{{ r.num_laps }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </article>
      </div>
      {% endfor %}
    </section>

    <section id="qualifying-panel" class="tab-panel">
      <nav class="sub-tabs">
        {% for s in qualifying_sessions %}
        <button class="tab-btn {% if loop.first %}active{% endif %}" data-group="qualifying" data-target="qualifying-{{ s.session_name|lower }}">{{ s.session_name }}</button>
        {% endfor %}
      </nav>

      {% if qualifying_sessions|length == 0 %}
      <div class="empty">No qualifying split data available for this round.</div>
      {% endif %}

      {% for s in qualifying_sessions %}
      <div id="qualifying-{{ s.session_name|lower }}" class="tab-panel {% if loop.first %}active{% endif %}">
        <article class="session">
          <h2>{{ s.session_name }}</h2>
          <div class="meta"><span>Drivers: {{ s.drivers }}</span><span>Laps: {{ s.laps }}</span></div>
          <div class="imggrid">
            {% for chart in s.charts %}
            <article class="chart">
              <h3>{{ chart.title }}</h3>
              <img class="{% if chart.title == 'Fastest Two Lap Delta' %}telemetry-large{% endif %}" src="assets/{{ chart.file }}?v={{ asset_version }}" alt="{{ s.session_name }} {{ chart.title }}" />
              <div class="insight-box">
                <p class="insight-title">Highlights</p>
                <ul>
                  {% for point in chart.insights %}
                  <li>{{ point }}</li>
                  {% endfor %}
                </ul>
              </div>
            </article>
            {% endfor %}
          </div>
          <table>
            <thead><tr><th>Pos</th><th>Driver</th><th>Team</th><th>S1 (s)</th><th>S2 (s)</th><th>S3 (s)</th><th>Best Lap (s)</th></tr></thead>
            <tbody>
              {% for r in s.table_rows %}
              <tr>
                <td>{{ r.session_position }}</td>
                <td>{{ r.Driver }}</td>
                <td>{{ r.Team }}</td>
                <td>{{ r.s1_time_fmt }}</td>
                <td>{{ r.s2_time_fmt }}</td>
                <td>{{ r.s3_time_fmt }}</td>
                <td>{{ r.best_lap_time_fmt }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </article>
      </div>
      {% endfor %}
    </section>

    <section id="race-panel" class="tab-panel">
      {% if race_session %}
      <article class="session">
        <h2>{{ race_session.session_name }}</h2>
        <div class="meta"><span>Drivers: {{ race_session.drivers }}</span><span>Laps: {{ race_session.laps }}</span></div>
        <div class="imggrid">
          {% for chart in race_session.charts %}
          <article class="chart">
            <h3>{{ chart.title }}</h3>
            <img class="{% if chart.title == 'Fastest Two Lap Delta' %}telemetry-large{% endif %}" src="assets/{{ chart.file }}?v={{ asset_version }}" alt="Race {{ chart.title }}" />
            <div class="insight-box">
              <p class="insight-title">Highlights</p>
              <ul>
                {% for point in chart.insights %}
                <li>{{ point }}</li>
                {% endfor %}
              </ul>
            </div>
          </article>
          {% endfor %}
        </div>
        <table>
          <thead><tr><th>Pos</th><th>Driver</th><th>Team</th><th>Median Pace (s)</th><th>Fastest Lap (s)</th><th>Stints</th></tr></thead>
          <tbody>
            {% for r in race_session.table_rows %}
            <tr>
              <td>{{ r.race_position|int }}</td>
              <td>{{ r.Driver }}</td>
              <td>{{ r.Team }}</td>
              <td>{{ r.median_pace_fmt }}</td>
              <td>{{ r.fastest_lap_fmt }}</td>
              <td>{{ r.stints if r.stints is not none else "" }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </article>
      {% else %}
      <div class="empty">Race data is not available yet.</div>
      {% endif %}
    </section>
  </div>

  {% if ga4_measurement_id %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga4_measurement_id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', '{{ ga4_measurement_id }}', { 'anonymize_ip': true });
  </script>
  {% endif %}
  <script>
    const analyticsEnabled = {{ "true" if ga4_measurement_id else "false" }};
    const tabTracker = (() => {
      const starts = {};
      function send(group, name, secs) {
        if (!analyticsEnabled || typeof gtag !== 'function' || secs < 1) return;
        gtag('event', 'tab_time', {
          tab_group: group,
          tab_name: name,
          time_seconds: Number(secs.toFixed(1)),
          season: {{ season }},
          round: {{ round_number }},
          event_name: '{{ event_name|e }}',
          page_name: 'Weekend Analysis'
        });
      }
      return {
        switch(group, name) {
          const now = Date.now();
          if (starts[group]) {
            send(group, starts[group].name, (now - starts[group].ts) / 1000);
          }
          starts[group] = { name, ts: now };
        },
        flushAll() {
          const now = Date.now();
          Object.keys(starts).forEach((group) => {
            const rec = starts[group];
            send(group, rec.name, (now - rec.ts) / 1000);
          });
        }
      };
    })();

    function activeButtonLabel(group) {
      const btn = document.querySelector(`.tab-btn[data-group="${group}"].active`);
      return btn ? btn.textContent.trim() : '';
    }

    function trackActiveSessionFromMain(mainTarget) {
      if (mainTarget === 'practice-panel') {
        tabTracker.switch('session', activeButtonLabel('practice') || 'Practice');
        return;
      }
      if (mainTarget === 'qualifying-panel') {
        tabTracker.switch('session', activeButtonLabel('qualifying') || 'Qualifying');
        return;
      }
      tabTracker.switch('session', 'Race');
    }

    function activateTab(button) {
      const group = button.dataset.group;
      const target = button.dataset.target;
      document.querySelectorAll(`.tab-btn[data-group="${group}"]`).forEach((btn) => btn.classList.remove('active'));
      button.classList.add('active');

      if (group === 'main') {
        ['practice-panel', 'qualifying-panel', 'race-panel'].forEach((id) => {
          const el = document.getElementById(id);
          if (!el) return;
          el.classList.toggle('active', id === target);
        });
        tabTracker.switch('main', button.textContent.trim());
        trackActiveSessionFromMain(target);
        return;
      }

      const subgroupButtons = document.querySelectorAll(`.tab-btn[data-group="${group}"]`);
      subgroupButtons.forEach((b) => {
        const panelId = b.dataset.target;
        const panel = document.getElementById(panelId);
        if (panel) panel.classList.remove('active');
      });
      const active = document.getElementById(target);
      if (active) active.classList.add('active');
      tabTracker.switch('session', button.textContent.trim());
    }

    document.querySelectorAll('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => activateTab(btn));
    });

    tabTracker.switch('page', 'Weekend Analysis');
    tabTracker.switch('main', activeButtonLabel('main') || 'Practice');
    trackActiveSessionFromMain('practice-panel');

    window.addEventListener('beforeunload', () => tabTracker.flushAll());
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') tabTracker.flushAll();
    });
  </script>
</body>
</html>
